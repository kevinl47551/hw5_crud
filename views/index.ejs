<!-- index.ejs -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Ideas</title>
  </head>

  <body>
    <h1>Idea tracker</h1>

    <form action="/ideas" method="POST">
      <input type="text" placeholder="Title" name="title" />
      <input type="text" placeholder="Decription" name="description" />
      <button type="submit">Submit</button>
    </form>
    <h2>Ideas</h2>

    <ul class="Ideas">
        <!-- Loop through quotes -->
        <% for(var i = 0; i < ideas.length; i++) {%>
        <li class="ideas">
            <!-- Output name from the iterated quote object -->
            <span><%= ideas[i].title %></span>:
            <!-- Output quote from the iterated quote object -->
            <span><%= ideas[i].description %></span>
        </li>
        <% } %>
    </ul>

    <div>
        <h2>Good Ideas</h2>
        <p>Replace your first ideas with better ideas</p>
        <input id="good" type="text" placeholder="title" name="oldTitle" />
        <button id="update-button">Replace ideas</button>
    </div>


    <div>
    <h2>Remove idea</h2>
    <p>
        delete one of your ideas
    </p>
    <input id="delete" type="text" placeholder="title" name="titleDelete" />
    <button id="delete-button">Delete idea</button>
    </div>
    <div id="message"></div>

    <script src="/main.js"></script>
    
  </body>
</html>